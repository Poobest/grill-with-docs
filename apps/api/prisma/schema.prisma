generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Platform Layer ───────────────────────────────────────────────────────────

model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  maxBranches   Int
  maxUsers      Int
  pricePerMonth Decimal  @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenants Tenant[]
}

model Tenant {
  id                    String    @id @default(cuid())
  name                  String
  isActive              Boolean   @default(true)
  planId                String
  subscriptionExpiresAt DateTime?
  defaultThreshold      Int       @default(3)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  plan        SubscriptionPlan @relation(fields: [planId], references: [id])
  users       User[]
  branches    Branch[]
  products    Product[]
  customers   Customer[]
  contracts   Contract[]
  payments    Payment[]
  commissions Commission[]
  lateFees    LateFee[]
}

model PlatformAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// ─── Tenant Layer ─────────────────────────────────────────────────────────────

enum UserRole {
  TENANT_ADMIN
  SALE_LEAD
  SALE
}

model User {
  id                        String   @id @default(cuid())
  tenantId                  String
  branchId                  String?
  role                      UserRole
  name                      String
  email                     String
  password                  String
  commissionRateCash        Decimal  @default(0) @db.Decimal(5, 2)
  commissionRateInstallment Decimal  @default(0) @db.Decimal(5, 2)
  isActive                  Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  branch           Branch?      @relation(fields: [branchId], references: [id])
  createdContracts Contract[]   @relation("ContractSale")
  approvedPayments Payment[]    @relation("PaymentApprover")
  commissions      Commission[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  users     User[]
  stocks    BranchStock[]
  contracts Contract[]

  @@index([tenantId])
}

model Product {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  cashPrice    Decimal  @db.Decimal(10, 2)
  downPayment  Decimal  @db.Decimal(10, 2)
  dailyPrice   Decimal  @db.Decimal(10, 2)
  weeklyPrice  Decimal  @db.Decimal(10, 2)
  monthlyPrice Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  stocks    BranchStock[]
  contracts Contract[]

  @@index([tenantId])
}

model BranchStock {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String
  productId String
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  branch  Branch  @relation(fields: [branchId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([branchId, productId])
  @@index([tenantId])
}

model Customer {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  phone         String
  lineUserId    String?  @unique
  contractLimit Int      @default(1)
  isSuspended   Boolean  @default(false)
  claimCode     String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  contracts Contract[]

  @@index([tenantId])
}

enum PaymentType {
  DAILY
  WEEKLY
  MONTHLY
  CASH
}

enum ContractStatus {
  PENDING
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
}

model Contract {
  id               String         @id @default(cuid())
  tenantId         String
  customerId       String
  productId        String
  branchId         String
  saleId           String
  paymentType      PaymentType
  status           ContractStatus @default(PENDING)
  totalAmount      Decimal        @db.Decimal(10, 2)
  downPaymentPaid  Boolean        @default(false)
  warrantyActive   Boolean        @default(false)
  installmentCount Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])
  branch   Branch    @relation(fields: [branchId], references: [id])
  sale     User      @relation("ContractSale", fields: [saleId], references: [id])
  payments Payment[]
  lateFees LateFee[]

  @@index([tenantId])
  @@index([customerId])
  @@index([saleId])
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  OVERDUE
}

enum PaymentMethod {
  CASH
  TRANSFER_SLIP
}

model Payment {
  id            String         @id @default(cuid())
  tenantId      String
  contractId    String
  amount        Decimal        @db.Decimal(10, 2)
  dueDate       DateTime
  paidAt        DateTime?
  status        PaymentStatus  @default(PENDING)
  method        PaymentMethod?
  slipImageUrl  String?
  isDownPayment Boolean        @default(false)
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  contract    Contract     @relation(fields: [contractId], references: [id])
  approvedBy  User?        @relation("PaymentApprover", fields: [approvedById], references: [id])
  commissions Commission[]

  @@index([tenantId])
  @@index([contractId])
  @@index([dueDate, status])
}

enum CommissionType {
  SALE_COMMISSION
  OVERRIDE_COMMISSION
}

model Commission {
  id        String         @id @default(cuid())
  tenantId  String
  paymentId String
  userId    String
  amount    Decimal        @db.Decimal(10, 2)
  type      CommissionType
  createdAt DateTime       @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
}

model LateFee {
  id         String   @id @default(cuid())
  tenantId   String
  contractId String
  amount     Decimal  @db.Decimal(10, 2)
  issuedAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  contract Contract @relation(fields: [contractId], references: [id])

  @@index([tenantId])
  @@index([contractId])
}
