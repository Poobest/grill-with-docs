generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Platform layer
// ─────────────────────────────────────────────────────────────────────────────

model PlatformAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String   @unique
  maxBranches   Int
  maxUsers      Int
  pricePerMonth Decimal  @db.Decimal(12, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenants Tenant[]
}

model Tenant {
  id                    String    @id @default(cuid())
  name                  String
  isActive              Boolean   @default(true)
  planId                String
  subscriptionExpiresAt DateTime?
  defaultThreshold      Int       @default(3)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  plan        SubscriptionPlan @relation(fields: [planId], references: [id])
  branches    Branch[]
  users       User[]
  products    Product[]
  customers   Customer[]
  contracts   Contract[]
  payments    Payment[]
  commissions Commission[]
  lateFees    LateFee[]
  stock       BranchStock[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenant layer
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  users     User[]
  stock     BranchStock[]
  contracts Contract[]
}

enum UserRole {
  ADMIN
  SALE_LEAD
  SALE
}

model User {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String?
  name            String
  email           String
  password        String
  role            UserRole
  installmentRate Decimal  @default(0) @db.Decimal(5, 4)
  cashRate        Decimal  @default(0) @db.Decimal(5, 4)
  overrideRate    Decimal  @default(0) @db.Decimal(5, 4)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  branch           Branch?      @relation(fields: [branchId], references: [id])
  contracts        Contract[]
  approvedPayments Payment[]    @relation("ApprovedBy")
  commissions      Commission[]

  @@unique([tenantId, email])
}

model Product {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  cashPrice    Decimal  @db.Decimal(12, 2)
  downPayment  Decimal  @db.Decimal(12, 2)
  dailyPrice   Decimal  @db.Decimal(12, 2)
  weeklyPrice  Decimal  @db.Decimal(12, 2)
  monthlyPrice Decimal  @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  stock     BranchStock[]
  contracts Contract[]
}

model BranchStock {
  tenantId  String
  branchId  String
  productId String
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@id([branchId, productId])
}

model Customer {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  phone         String
  lineUserId    String?
  contractLimit Int      @default(1)
  isSuspended   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  contracts Contract[]
}

enum PaymentType {
  DAILY
  WEEKLY
  MONTHLY
  CASH
}

enum ContractStatus {
  PENDING_DOWN_PAYMENT
  ACTIVE
  COMPLETED
  CANCELLED
  DEFAULTED
}

model Contract {
  id               String         @id @default(cuid())
  tenantId         String
  customerId       String
  productId        String
  branchId         String
  saleId           String
  paymentType      PaymentType
  totalAmount      Decimal        @db.Decimal(12, 2)
  installmentCount Int
  status           ContractStatus @default(PENDING_DOWN_PAYMENT)
  downPaymentPaid  Boolean        @default(false)
  warrantyActive   Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])
  branch   Branch    @relation(fields: [branchId], references: [id])
  sale     User      @relation(fields: [saleId], references: [id])
  payments Payment[]
  lateFees LateFee[]
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  CASH
  TRANSFER_SLIP
}

model Payment {
  id            String         @id @default(cuid())
  tenantId      String
  contractId    String
  amount        Decimal        @db.Decimal(12, 2)
  dueDate       DateTime
  isDownPayment Boolean        @default(false)
  status        PaymentStatus  @default(PENDING)
  method        PaymentMethod?
  slipImageUrl  String?
  paidAt        DateTime?
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  contract    Contract     @relation(fields: [contractId], references: [id])
  approvedBy  User?        @relation("ApprovedBy", fields: [approvedById], references: [id])
  commissions Commission[]
  lateFees    LateFee[]
}

model Commission {
  id        String   @id @default(cuid())
  tenantId  String
  paymentId String
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  type      String
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model LateFee {
  id         String   @id @default(cuid())
  tenantId   String
  contractId String
  paymentId  String
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  contract Contract @relation(fields: [contractId], references: [id])
  payment  Payment  @relation(fields: [paymentId], references: [id])
}
